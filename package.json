{
  "name": "ai-contract-auditor",
  "version": "0.1.0",
  "description": "AI-powered Solidity smart contract security auditor — combines static analysis (Slither) with GPT-5.6 reasoning via Codex to explain vulnerabilities in plain English and generate audit reports.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && next build",
    "audit": "tsx src/index.ts",
    "dev": "next dev",
    "dev:cli": "tsx watch src/index.ts",
    "web:build": "next build",
    "start": "next start -p 8080",
    "lint": "next lint"
  },
  "bin": {
    "ai-audit": "./dist/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "openai": "^4.60.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "dotenv": "^16.4.5",
    "next": "^14.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "tsx": "^4.19.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7"
  },
  "engines": {
    "node": ">=18"
  }
}
